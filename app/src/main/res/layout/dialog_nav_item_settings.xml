<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#2e2b2b"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Item Settings"
        android:textColor="#e8e2d9"
        android:textSize="15sp"
        android:fontFamily="monospace"
        android:paddingBottom="16dp" />

    <!-- Rename -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Label"
        android:textColor="#7a7270"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <EditText
        android:id="@+id/etLabel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:background="#1a1818"
        android:textColor="#e8e2d9"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:paddingStart="10dp"
        android:paddingEnd="10dp" />

    <!-- Text Size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Text Size"
            android:textColor="#7a7270"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvTextSizeVal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e8e2d9"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seekTextSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <!-- Show Icon toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show Icon"
            android:textColor="#7a7270"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <Switch
            android:id="@+id/switchShowIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDialogCancel"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textSize="12sp"
            android:background="@drawable/btn_dark_rounded"
            app:backgroundTint="@null"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <Button
            android:id="@+id/btnDialogSave"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Save"
            android:textSize="12sp"
            android:background="@drawable/btn_dark_rounded"
            app:backgroundTint="@null"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>

</LinearLayout>